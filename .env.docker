# ===================================
# AEGIS Docker 部署环境变量
# ===================================
# 复制此文件为 .env 并填入真实值
# cp .env.docker .env
# docker-compose up -d
# ===================================

# ===================================
# MySQL (Docker 内置，无需修改)
# ===================================
MYSQL_ROOT_PASSWORD=root123
DB_USER=root
DB_PASSWORD=root123
DB_NAME=for_student
DB_CHARSET=utf8mb4
MYSQL_PORT=33061
BASE_DB_NAME=ric_ai_base

# ===================================
# Redis (Docker 内置，无需修改)
# ===================================
REDIS_PORT=6379

# ===================================
# Neo4j (Docker 内置，无需修改)
# ===================================
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j123

# ===================================
# MinIO (Docker 内置，无需修改)
# ===================================
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ===================================
# Milvus (Docker 内置，无需修改)
# ===================================

# ===================================
# LLM / AI (【需要填写】)
# ===================================
LLM_TIMEOUT=30
MY_DASHSCOPE_API_KEY=sk-你的阿里云DashScope密钥
QWEN_DEFAULT_MODEL=qwen3-max
QWEN_EMBEDDING_MODEL_NAME=text-embedding-v3
QWEN_ASR_MODEL_NAME=qwen3-asr-flash
QWEN_OCR_MODEL_NAME=qwen-vl-ocr-latest

DEEPSEEK_DEFAULT_MODEL=deepseek-chat
DEEPSEEK_API_KEY=sk-你的DeepSeek密钥
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ===================================
# Tencent COS (【需要填写】)
# ===================================
TC_SECRET_ID=你的腾讯云SecretId
TC_SECRET_KEY=你的腾讯云SecretKey
TC_REGION=ap-guangzhou
TC_BUCKET_NAME=你的Bucket名称
TC_SCHEME=https

# ===================================
# Email (【需要填写】)
# ===================================
EMAIL_PASSWORD=你的邮箱授权码
SENDER_EMAIL=你的发送邮箱@qq.com

# ===================================
# TTS (可选)
# ===================================
TTS_SERVER_URL=http://47.115.57.130:50000/
TTS_BUCKET_NAME=tts-audio-cache

# ===================================
# Auth JWT (【需要填写】生产环境请设置随机密钥)
# ===================================
AUTH_JWT_SECRET=请生成一个随机密钥

# ===================================
# 日志
# ===================================
LOG_LEVEL=INFO

# ===================================
# 服务端口
# ===================================
BASE_API_PORT=8010
COMPFOX_API_PORT=8003
